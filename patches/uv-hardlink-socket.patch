+/// Return the `UV_HARDLINK_SOCKET` path if set, cached for the process lifetime.
+fn hardlink_socket_path() -> Option<&'static str> {
+    static SOCKET: OnceLock<Option<String>> = OnceLock::new();
+    SOCKET
+        .get_or_init(|| std::env::var("UV_HARDLINK_SOCKET").ok().filter(|s| !s.is_empty()))
+        .as_deref()
+}
