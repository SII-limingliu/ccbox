+/// Escape a string for embedding in a JSON value (handles `\` and `"`).
+fn json_escape(s: &str) -> String {
+    let mut out = String::with_capacity(s.len() + 2);
+    out.push('"');
+    for c in s.chars() {
+        match c {
+            '\\' => out.push_str("\\\\"),
+            '"' => out.push_str("\\\""),
+            '\n' => out.push_str("\\n"),
+            '\r' => out.push_str("\\r"),
+            '\t' => out.push_str("\\t"),
+            c => out.push(c),
+        }
+    }
+    out.push('"');
+    out
+}
+
+/// Request a hardlink via the host-side ccbox server over a Unix socket.
+///
+/// Protocol: send `{"src":"...","dst":"..."}\n`, receive `{"ok":true}\n` or
+/// `{"ok":false,"error":"..."}\n`.
+fn remote_hardlink(src: &Path, dst: &Path, socket_path: &str) -> io::Result<()> {
+    let mut stream = UnixStream::connect(socket_path)?;
+    stream.set_read_timeout(Some(std::time::Duration::from_secs(30)))?;
+
+    let request = format!(
+        "{{\"src\":{},\"dst\":{}}}\n",
+        json_escape(&src.to_string_lossy()),
+        json_escape(&dst.to_string_lossy()),
+    );
+    stream.write_all(request.as_bytes())?;
+
+    let mut reader = io::BufReader::new(&stream);
+    let mut response = String::new();
+    reader.read_line(&mut response)?;
+
+    // Parse minimal JSON response
+    if response.contains("\"ok\":true") || response.contains("\"ok\": true") {
+        Ok(())
+    } else if let Some(start) = response.find("\"error\":") {
+        let msg = response[start + 8..]
+            .trim()
+            .trim_start_matches('"')
+            .split('"')
+            .next()
+            .unwrap_or("unknown error");
+        Err(io::Error::new(io::ErrorKind::Other, msg.to_string()))
+    } else {
+        Err(io::Error::new(
+            io::ErrorKind::Other,
+            format!("unexpected response from hardlink server: {response}"),
+        ))
+    }
+}
+
